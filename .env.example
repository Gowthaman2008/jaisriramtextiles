# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only, never expose to client

# ---- Cloudinary ----
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ADMIN_UPLOAD_PASSWORD=            # gates /admin/upload until real admin auth (Phase 5) lands

# ---- Razorpay ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Groq (AI chatbot) ----
GROQ_API_KEY=

# ---- Resend (transactional emails, e.g. Google sign-up welcome email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=            # e.g. "Jai Sri Ram Textiles <onboarding@resend.dev>" until a custom domain is verified

# ---- Google Sheets (new-signup append) ----
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
