*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
assets/** filter=lfs diff=lfs merge=lfs -text

# Exclude logo, icon, and favicon files from LFS so they compile properly on Vercel
src/app/favicon.ico -filter -diff -merge
src/app/icon.png -filter -diff -merge
src/app/apple-icon.png -filter -diff -merge
public/favicon.png -filter -diff -merge
public/favicon.ico -filter -diff -merge
public/apple-touch-icon.png -filter -diff -merge
public/og-image.png -filter -diff -merge
